// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")  // pooler URL (pgbouncer) — runtime
  directUrl = env("DIRECT_URL")    // non-pooled — migrations only
}

// ─── Users ─────────────────────────────────────────────────────────────────

model User {
  id            Int       @id @default(autoincrement())
  username      String    @unique @db.VarChar(50)
  email         String    @unique @db.VarChar(255)
  password      String?   @db.VarChar(255)
  googleId      String?   @unique @map("google_id") @db.VarChar(255)
  emailVerified Boolean   @default(false) @map("email_verified")
  
  // Profile fields
  dateOfBirth    DateTime? @map("date_of_birth") @db.Date
  gender         String?   @db.VarChar(20) // male, female, other, prefer-not-to-say
  country        String?   @db.VarChar(100)
  bio            String?   @db.Text
  favoriteStyles String[]  @default([]) @map("favorite_styles")
  
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  favorites          UserFavorite[]
  lists              UserList[]
  searchHistory      SearchHistory[]
  emailVerifications EmailVerification[]
  refreshTokens      RefreshToken[]
  itineraries        UserItinerary[]

  @@map("users")
}

// ─── Beers (Gemini-enriched cache) ─────────────────────────────────────────

model Beer {
  // slug derived from the canonical beer name, e.g. "pliny-the-elder"
  id          String   @id @db.VarChar(200)
  beerName    String   @map("beer_name") @db.VarChar(200)
  brewery     String   @db.VarChar(200)
  style       String   @db.VarChar(100)
  abv         Float?   @map("abv")
  ibu         Int?     @map("ibu")
  checkIns    Int?     @map("check_ins")
  ratingScore Float?   @map("rating_score")
  ratingCount Int?     @map("rating_count")
  description String?  @map("description") @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  favorites UserFavorite[]
  listItems ListItem[]
  beerTags  BeerTag[]

  @@map("beers")
}

// ─── Favorites ─────────────────────────────────────────────────────────────

model UserFavorite {
  id      Int      @id @default(autoincrement())
  userId  Int      @map("user_id")
  beerId  String   @map("beer_id")
  addedAt DateTime @default(now()) @map("added_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  beer Beer @relation(fields: [beerId], references: [id], onDelete: Cascade)

  @@unique([userId, beerId])
  @@map("user_favorites")
}

// ─── Lists ─────────────────────────────────────────────────────────────────

model UserList {
  id          Int      @id @default(autoincrement())
  userId      Int      @map("user_id")
  name        String   @db.VarChar(100)
  description String?  @db.VarChar(500)
  isPublic    Boolean  @default(false) @map("is_public")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items ListItem[]

  @@map("user_lists")
}

model ListItem {
  id      Int      @id @default(autoincrement())
  listId  Int      @map("list_id")
  beerId  String   @map("beer_id")
  notes   String?  @db.VarChar(500)
  addedAt DateTime @default(now()) @map("added_at")

  list UserList @relation(fields: [listId], references: [id], onDelete: Cascade)
  beer Beer     @relation(fields: [beerId], references: [id], onDelete: Cascade)

  @@unique([listId, beerId])
  @@map("list_items")
}

// ─── Search History ─────────────────────────────────────────────────────────

model SearchHistory {
  id          Int      @id @default(autoincrement())
  userId      Int?     @map("user_id")
  query       String   @db.Text
  source      String   @db.VarChar(20) // "single" | "list" | "image"
  resultCount Int      @default(0) @map("result_count")
  createdAt   DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("search_history")
}

// ─── Auth tokens ────────────────────────────────────────────────────────────

model EmailVerification {
  id        Int       @id @default(autoincrement())
  userId    Int       @map("user_id")
  codeHash  String    @map("code_hash") @db.VarChar(255)
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("email_verifications")
}

model RefreshToken {
  id        Int       @id @default(autoincrement())
  userId    Int       @map("user_id")
  tokenHash String    @map("token_hash") @db.VarChar(255)
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

// ─── Tags ──────────────────────────────────────────────────────────────────

model Tag {
  id   Int    @id @default(autoincrement())
  name String @unique @db.VarChar(50)

  beerTags BeerTag[]

  @@map("tags")
}

model BeerTag {
  beerId String @map("beer_id")
  tagId  Int    @map("tag_id")

  beer Beer @relation(fields: [beerId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([beerId, tagId])
  @@map("beer_tags")
}

// ─── Festivals ─────────────────────────────────────────────────────────────

model Festival {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(200)
  city        String   @db.VarChar(100)
  country     String   @db.VarChar(100)
  continent   String   @db.VarChar(50)
  startDate   DateTime @map("start_date") @db.Date
  endDate     DateTime @map("end_date") @db.Date
  description String?  @db.Text
  website     String?  @db.VarChar(500)
  imageUrl    String?  @map("image_url") @db.VarChar(500)
  latitude    Float?
  longitude   Float?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  itineraries UserItinerary[]

  @@map("festivals")
}

model UserItinerary {
  id            Int      @id @default(autoincrement())
  userId        Int      @map("user_id")
  festivalId    Int      @map("festival_id")
  arrivalDate   DateTime @map("arrival_date") @db.Date
  departureDate DateTime @map("departure_date") @db.Date
  generatedPlan Json     @map("generated_plan")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  festival Festival @relation(fields: [festivalId], references: [id], onDelete: Cascade)

  @@map("user_itineraries")
}

// ─── Beer of the Day ───────────────────────────────────────────────────────

model BeerOfTheDay {
  id        Int      @id @default(autoincrement())
  date      DateTime @unique @db.Date
  beerName  String   @map("beer_name") @db.VarChar(200)
  beerData  Json     @map("beer_data")
  funFact   String?  @map("fun_fact") @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  @@map("beer_of_the_day")
}
